{% extends 'base.html.twig' %}
{% block title %}{{ client.displayName }}{% endblock %}
{% block heading %}{{ client.displayName }}{% endblock %}
{% block body %}
<div class="grid stats">
    <div class="stat"><div class="muted">Кімната</div><div class="value">{{ client.roomNumber ?: '-' }}</div></div>
    <div class="stat"><div class="muted">Телефон</div><div class="value">{{ client.phone ?: '-' }}</div></div>
    <div class="stat"><div class="muted">Пристрої</div><div class="value">{{ devices|length }}</div></div>
    <div class="stat"><div class="muted">Сьогодні</div><div class="value">{{ (today / 1048576)|number_format(1) }} МБ</div></div>
    <div class="stat"><div class="muted">Вхідний</div><div class="value">{{ (todayDownload / 1048576)|number_format(1) }} МБ</div></div>
    <div class="stat"><div class="muted">Вихідний</div><div class="value">{{ (todayUpload / 1048576)|number_format(1) }} МБ</div></div>
</div>
<div class="grid two">
    <section class="panel"><h2>Активність за 30 днів</h2><canvas id="clientUsage" height="160"></canvas></section>
    <section class="panel">
        <h2>Пристрої</h2>
        <table>
            <tr><th>MAC</th><th>IP</th><th>Ім'я хоста</th><th>VLAN</th><th>Усього</th><th>Вхідний</th><th>Вихідний</th><th>Коментар</th></tr>
            {% for row in deviceRows %}
                {% set device = row.device %}
                <tr>
                    <td><a href="{{ path('device_show',{id:device.id}) }}">{{ device.mac }}</a></td>
                    <td>{{ device.currentIp }}</td>
                    <td>{{ device.hostname }}</td>
                    <td>{{ device.vlan }}</td>
                    <td>{{ (row.today / 1048576)|number_format(1) }} МБ</td>
                    <td>{{ (row.todayDownload / 1048576)|number_format(1) }} МБ</td>
                    <td>{{ (row.todayUpload / 1048576)|number_format(1) }} МБ</td>
                    <td>{{ device.comment ?: '-' }}</td>
                </tr>
            {% else %}
                <tr><td colspan="8">Немає даних</td></tr>
            {% endfor %}
        </table>
    </section>
</div>
<div class="grid two">
    <section class="panel">
        <h2>Останні домени</h2>
        <table>
            <thead><tr><th>Домен</th><th>Останнє</th><th>Обсяг</th></tr></thead>
            <tbody id="recent-domains-body">
                <tr><td colspan="3" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Топ доменів за сьогодні</h2>
        <table>
            <thead><tr><th>Домен</th><th>Обсяг</th></tr></thead>
            <tbody id="top-domains-body">
                <tr><td colspan="2" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
</div>
<div class="grid two">
    <section class="panel">
        <h2>Топ застосунків за сьогодні</h2>
        <table>
            <thead><tr><th>Застосунок</th><th>Обсяг</th></tr></thead>
            <tbody id="top-apps-body">
                <tr><td colspan="2" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Остання активність</h2>
        <table>
            <thead><tr><th>Час</th><th>Домен / застосунок</th><th>Напрямок</th><th>Обсяг</th></tr></thead>
            <tbody id="recent-activity-body">
                <tr><td colspan="4" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
{% block scripts %}
<script>
const trafficUrl = {{ path('api_client_traffic', {id: client.id})|json_encode|raw }};
const clientUsageChart = new Chart(document.getElementById('clientUsage'), {
  type: 'bar',
  data: {
    labels: [],
    datasets: [{
      label: 'МБ',
      data: [],
      backgroundColor: '#0f766e'
    }]
  },
  options: {
    plugins: {
      legend: {
        display: false
      }
    }
  }
});

function formatBytes(bytes) {
  const value = Number(bytes) || 0;
  if (value >= 1073741824) return `${(value / 1073741824).toFixed(1)} GB`;
  if (value >= 1048576) return `${(value / 1048576).toFixed(1)} МБ`;
  if (value >= 1024) return `${Math.round(value / 1024)} КБ`;
  return `${value} B`;
}

function renderRows(tbodyId, rows, columns, renderer) {
  const tbody = document.getElementById(tbodyId);
  const rendered = rows.map(renderer);
  if (rendered.length === 0) {
    const line = document.createElement('tr');
    const cell = document.createElement('td');
    cell.colSpan = columns;
    cell.className = 'muted';
    cell.textContent = 'Немає даних';
    line.appendChild(cell);
    tbody.replaceChildren(line);
    return;
  }
  tbody.replaceChildren(...rendered);
}

function td(text) {
  const cell = document.createElement('td');
  cell.textContent = text ?? '-';
  return cell;
}

fetch(trafficUrl, { headers: { Accept: 'application/json' } })
  .then((response) => response.ok ? response.json() : Promise.reject(new Error(`Traffic API ${response.status}`)))
  .then((data) => {
    const daily = data.daily || [];
    clientUsageChart.data.labels = daily.map((row) => row.date);
    clientUsageChart.data.datasets[0].data = daily.map((row) => Math.round((Number(row.bytes) || 0) / 104857.6) / 10);
    clientUsageChart.update();

    renderRows('recent-domains-body', data.recentDomains || [], 3, (row) => {
      const line = document.createElement('tr');
      line.appendChild(td(row.domain));
      line.appendChild(td(row.lastSeenAt ? new Date(row.lastSeenAt).toLocaleString() : '-'));
      line.appendChild(td(formatBytes(row.bytes)));
      return line;
    });
    renderRows('top-domains-body', data.topDomainsToday || [], 2, (row) => {
      const line = document.createElement('tr');
      line.appendChild(td(row.domain));
      line.appendChild(td(formatBytes(row.bytes)));
      return line;
    });
    renderRows('top-apps-body', Object.entries(data.topAppsToday || {}), 2, ([app, bytes]) => {
      const line = document.createElement('tr');
      line.appendChild(td(app));
      line.appendChild(td(formatBytes(bytes)));
      return line;
    });
    renderRows('recent-activity-body', data.recentActivity || [], 4, (row) => {
      const line = document.createElement('tr');
      line.appendChild(td(row.receivedAt ? new Date(row.receivedAt).toLocaleString() : '-'));
      line.appendChild(td(row.label));
      line.appendChild(td(row.direction));
      line.appendChild(td(formatBytes(row.bytes)));
      return line;
    });
  })
  .catch((error) => console.warn('Client traffic load failed', error));
</script>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}{{ client.displayName }}{% endblock %}
{% block heading %}{{ client.displayName }}{% endblock %}
{% block body %}
<div class="grid stats">
    <div class="stat"><div class="muted">Кімната</div><div class="value">{{ client.roomNumber ?: '-' }}</div></div>
    <div class="stat"><div class="muted">Телефон</div><div class="value">{{ client.phone ?: '-' }}</div></div>
    <div class="stat"><div class="muted">Пристрої</div><div class="value">{{ devices|length }}</div></div>
</div>
<div class="grid two">
    <section class="panel"><h2>Активність за 30 днів</h2><canvas id="clientUsage" height="160"></canvas></section>
    <section class="panel"><h2>Пристрої</h2><table><tr><th>MAC</th><th>IP</th><th>Ім'я хоста</th><th>VLAN</th></tr>{% for device in devices %}<tr><td><a href="{{ path('device_show',{id:device.id}) }}">{{ device.mac }}</a></td><td>{{ device.currentIp }}</td><td>{{ device.hostname }}</td><td>{{ device.vlan }}</td></tr>{% else %}<tr><td colspan="4">Немає даних</td></tr>{% endfor %}</table></section>
</div>
<div class="grid two">
    <section class="panel">
        <h2>Останні домени</h2>
        <table>
            <thead><tr><th>Домен</th><th>Останнє</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for row in recentDomains %}
                <tr>
                    <td>{{ row.domain }}</td>
                    <td>{{ row.lastSeenAt ? row.lastSeenAt|date('Y-m-d H:i') : '-' }}</td>
                    <td>{{ (row.bytes / 1048576)|number_format(1) }} МБ</td>
                </tr>
            {% else %}
                <tr><td colspan="3">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Топ доменів за сьогодні</h2>
        <table>
            <thead><tr><th>Домен</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for row in topDomainsToday %}
                <tr><td>{{ row.domain }}</td><td>{{ (row.bytes / 1048576)|number_format(1) }} МБ</td></tr>
            {% else %}
                <tr><td colspan="2">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
<div class="grid two">
    <section class="panel">
        <h2>Топ застосунків за сьогодні</h2>
        <table>
            <thead><tr><th>Застосунок</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for app, bytes in topAppsToday %}
                <tr><td>{{ app }}</td><td>{{ (bytes / 1048576)|number_format(1) }} МБ</td></tr>
            {% else %}
                <tr><td colspan="2">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Остання активність</h2>
        <table>
            <thead><tr><th>Час</th><th>Домен / застосунок</th><th>Напрямок</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for row in recentActivity %}
                <tr>
                    <td>{{ row.receivedAt ? row.receivedAt|date('Y-m-d H:i') : '-' }}</td>
                    <td>{{ row.label }}</td>
                    <td>{{ row.direction }}</td>
                    <td>{{ (row.bytes / 1048576)|number_format(1) }} МБ</td>
                </tr>
            {% else %}
                <tr><td colspan="4">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
{% block scripts %}
<script>
new Chart(document.getElementById('clientUsage'), {
  type: 'bar',
  data: { labels: {{ daily|keys|json_encode|raw }}, datasets: [{ label: 'МБ', data: {{ daily|map(v => (v / 1048576)|round(1))|json_encode|raw }}, backgroundColor: '#0f766e' }] },
  options: { plugins: { legend: { display: false } } }
});
</script>
{% endblock %}

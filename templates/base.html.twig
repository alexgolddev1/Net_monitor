<!doctype html>
<html lang="uk">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ app_name }}{% endblock %}</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
    <style>
        :root { --bg:#f6f7f9; --panel:#fff; --text:#1f2937; --muted:#6b7280; --line:#d8dee8; --accent:#0f766e; --warn:#b45309; }
        * { box-sizing: border-box; }
        body { margin:0; font-family: Inter, system-ui, -apple-system, Segoe UI, sans-serif; background:var(--bg); color:var(--text); }
        a { color:var(--accent); text-decoration:none; }
        .layout { display:grid; grid-template-columns:240px 1fr; min-height:100vh; }
        .sidebar { background:#111827; color:#f9fafb; padding:24px 18px; }
        .brand { font-size:20px; font-weight:700; margin-bottom:24px; }
        .nav a { display:block; color:#d1d5db; padding:10px 12px; border-radius:6px; margin-bottom:4px; }
        .nav a:hover { background:#1f2937; color:#fff; }
        .content { padding:24px; min-width:0; }
        .topbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:16px; }
        .topbar-actions { display:flex; align-items:center; gap:10px; flex-wrap:wrap; justify-content:flex-end; }
        .topbar-actions form { margin:0; }
        .cache-actions { display:grid; gap:4px; justify-items:start; }
        .cache-meta { font-size:12px; color:var(--muted); line-height:1.2; }
        h1 { font-size:26px; margin:0; }
        h2 { font-size:18px; margin:0 0 12px; }
        .grid { display:grid; gap:16px; }
        .stats { grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); margin-bottom:18px; }
        .stat,.panel,.card { background:var(--panel); border:1px solid var(--line); border-radius:8px; padding:16px; }
        .stat .value { font-size:25px; font-weight:750; margin-top:8px; }
        .muted { color:var(--muted); }
        table { width:100%; border-collapse:collapse; background:#fff; border:1px solid var(--line); border-radius:8px; overflow:hidden; }
        th,td { padding:10px 12px; border-bottom:1px solid var(--line); text-align:left; vertical-align:top; font-size:14px; }
        th { background:#eef2f7; color:#374151; font-weight:650; }
        tr:last-child td { border-bottom:0; }
        .btn,button { background:var(--accent); color:#fff; border:0; border-radius:6px; padding:8px 11px; cursor:pointer; font-weight:650; }
        .btn.secondary { background:#4b5563; }
        input,select,textarea { width:100%; padding:8px 10px; border:1px solid var(--line); border-radius:6px; background:#fff; }
        label { display:block; font-size:13px; color:#374151; margin:8px 0 4px; }
        .form-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:10px; align-items:end; }
        .flash { background:#ecfdf5; border:1px solid #a7f3d0; color:#065f46; padding:10px 12px; border-radius:8px; margin-bottom:12px; }
        .two { grid-template-columns:minmax(0,1fr) minmax(0,1fr); }
        .favicon { width:18px; height:18px; vertical-align:middle; margin-right:8px; border-radius:4px; }
        @media (max-width: 820px) { .layout { grid-template-columns:1fr; } .sidebar { position:static; } .two { grid-template-columns:1fr; } table { display:block; overflow-x:auto; } }
    </style>
</head>
<body>
<div class="layout">
    <aside class="sidebar">
        <div class="brand">{{ app_name }}</div>
        <nav class="nav">
            <a href="{{ path('dashboard') }}">Панель</a>
            <a href="{{ path('clients') }}">Клієнти</a>
            <a href="{{ path('devices') }}">Пристрої</a>
            <a href="{{ path('reports') }}">Звіти</a>
            <a href="{{ path('app_logout') }}">Вийти</a>
        </nav>
    </aside>
    <main class="content">
        <div class="topbar">
            <h1>{% block heading %}{{ app_name }}{% endblock %}</h1>
            <div class="topbar-actions">
                <span class="muted">MikroTik + моніторинг трафіку</span>
                <div class="cache-actions">
                    <form method="post" action="{{ path('clients_refresh') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('clients_refresh') }}">
                        <button type="submit" class="btn secondary">Оновити клієнтів</button>
                    </form>
                    <div class="cache-meta">
                        Оновлено:
                        {% if page_cache.clientsCacheUpdatedAt() %}
                            {{ page_cache.clientsCacheUpdatedAt()|date('Y-m-d H:i') }}
                        {% else %}
                            ще не оновлено
                        {% endif %}
                    </div>
                </div>
                <div class="cache-actions">
                    <form method="post" action="{{ path('devices_refresh') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('devices_refresh') }}">
                        <button type="submit" class="btn secondary">Оновити пристрої</button>
                    </form>
                    <div class="cache-meta">
                        Оновлено:
                        {% if page_cache.devicesCacheUpdatedAt() %}
                            {{ page_cache.devicesCacheUpdatedAt()|date('Y-m-d H:i') }}
                        {% else %}
                            ще не оновлено
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% for message in app.flashes('success') %}
            <div class="flash">{{ message }}</div>
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
</div>
{% block scripts %}{% endblock %}
</body>
</html>

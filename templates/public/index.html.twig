{% extends 'base.html.twig' %}
{% block title %}Мережа КПДІ{% endblock %}
{% block heading %}Перевірка пристрою{% endblock %}
{% block body %}
<div class="grid two public-two">
    <section class="panel">
        <h2>Ваш пристрій</h2>


        {% if message %}
            <div class="flash" style="margin-top:12px;">{{ message }}</div>
        {% endif %}

        {% if not profileRequestsReady %}
            <div class="muted" style="margin-top:12px;">Модуль запитів змін ще не активований. Потрібно застосувати міграцію.</div>
        {% endif %}

        {% if device %}
            <div class="grid stats" style="margin-top:16px;">
                <div class="stat"><div class="muted">MAC</div><div class="value">{{ device.mac }}</div></div>
                <div class="stat"><div class="muted">IP</div><div class="value">{{ device.currentIp ?: '-' }}</div></div>
                <div class="stat"><div class="muted">Завантажено</div><div class="value">{{ deviceDetail.todayDownload|format_bytes }}</div></div>
                <div class="stat"><div class="muted">Вигружено</div><div class="value">{{ deviceDetail.todayUpload|format_bytes }}</div></div>
            </div>

            <div class="muted" style="margin-top:8px;">
                {% if device.client %}
                    Поточні дані: {{ device.client.displayName }}{% if device.client.roomNumber %}, кімната {{ device.client.roomNumber }}{% endif %}
                {% else %}
                    Клієнт не прив'язаний
                {% endif %}
            </div>
        {% endif %}
    </section>

    <section class="panel">
        <h2>Змінити персональні дані</h2>
        {% if device %}
            <form method="post" style="display:grid; gap:10px;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('public_device_profile_request') }}">
                <input type="hidden" name="device_id" value="{{ device.id }}">
                <input type="hidden" name="identifier" value="{{ identifier }}">
                <div class="form-grid">
                    <div>
                        <label>ПІБ</label>
                        <input name="full_name" value="{{ device.client ? device.client.fullName : '' }}" placeholder="Наприклад, Іван Петренко">
                    </div>
                    <div>
                        <label>Кімната</label>
                        <input name="room_number" value="{{ device.client ? device.client.roomNumber : '' }}" placeholder="Наприклад, 101">
                    </div>
                    <div>
                        <label>Телефон</label>
                        <input name="phone" value="{{ device.client ? device.client.phone : '' }}" placeholder="+380...">
                    </div>
                    <div>
                        <label>Коментар</label>
                        <input name="comment" value="{{ device.client ? device.client.comment : '' }}" placeholder="Додаткова примітка">
                    </div>
                </div>
                <div class="muted">Зміни будуть застосовані тільки після підтвердження адміністратором.</div>
                {% if not profileRequestsReady %}
                    <div class="muted">Збереження запитів тимчасово недоступне до міграції бази.</div>
                {% endif %}
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <button type="submit">Надіслати на підтвердження</button>
                </div>
            </form>

            {% if pendingRequests is not empty %}
                <div style="margin-top:18px;">
                    <h2>Очікує підтвердження</h2>
                    <table>
                        <tr><th>ПІБ</th><th>Кімната</th><th>Телефон</th><th>Коментар</th><th>Створено</th></tr>
                        {% for item in pendingRequests %}
                            <tr>
                                <td>{{ item.fullName ?: '-' }}</td>
                                <td>{{ item.roomNumber ?: '-' }}</td>
                                <td>{{ item.phone ?: '-' }}</td>
                                <td>{{ item.comment ?: '-' }}</td>
                                <td>{{ item.createdAt|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% endfor %}
                    </table>
                </div>
            {% endif %}
        {% else %}
            <div class="muted">Введіть IP або MAC, щоб побачити статистику та відправити правки.</div>
        {% endif %}
    </section>
</div>
<div class="grid two" style="margin-top:16px;">
    <section class="panel speedtest-shell">
        <div class="speedtest-header">
            <div>
                <h2 style="margin-bottom:6px;">Тест локальної мережі</h2>
                <div class="speedtest-status">Перевірка йде до цього сервера. Це показує якість каналу від вашого пристрою до панелі всередині локальної мережі.</div>
            </div>
            <div class="speedtest-actions">
                <button type="button" id="speedtest-start">Запустити тест</button>
                <button type="button" id="speedtest-stop" class="btn secondary" disabled>Зупинити</button>
            </div>
        </div>

        <div class="speedtest-progress">
            <div class="speedtest-bar" aria-hidden="true"><span id="speedtest-bar"></span></div>
            <div class="speedtest-logs" id="speedtest-log">Натисніть "Запустити тест", щоб почати.</div>
        </div>

        <div class="speedtest-results">
            <div class="speedtest-result">
                <div class="label">Ping</div>
                <div class="value" id="speedtest-ping">-</div>
                <div class="meta">Середня затримка</div>
            </div>
            <div class="speedtest-result">
                <div class="label">Download</div>
                <div class="value" id="speedtest-download">-</div>
                <div class="meta">Завантаження з сервера</div>
            </div>
            <div class="speedtest-result">
                <div class="label">Upload</div>
                <div class="value" id="speedtest-upload">-</div>
                <div class="meta">Відправка на сервер</div>
            </div>
            <div class="speedtest-result">
                <div class="label">Статус</div>
                <div class="value" id="speedtest-status">Готово</div>
                <div class="meta" id="speedtest-detail">Очікує запуску</div>
            </div>
        </div>
    </section>

    <section class="panel">
        <div class="speedtest-header">
            <div>
                <h2 style="margin-bottom:6px;">Тест у зовнішній світ</h2>
                <div class="speedtest-external-note">
                    Для зовнішнього тесту використовується офіційний popup Speedtest від 2IP / speedtest.net.ua. Він міряє інтернет-канал до зовнішніх серверів, а не локальну мережу.
                </div>
            </div>
            <div class="speedtest-actions">
                <button type="button" class="btn" id="external-speedtest-start">Запустити Speedtest</button>
                <a class="btn secondary" href="https://2ip.ua/ru/myspeed" target="_blank" rel="noopener noreferrer">Відкрити в новій вкладці</a>
            </div>
        </div>
        <div class="speedtest-external-note" style="margin-top:10px;">
            Popup відкриється окремим вікном. Якщо браузер його блокує, використайте кнопку відкриття у вкладці.
        </div>
    </section>
</div>
{% endblock %}
{% block scripts %}
<script>
const speedtestEndpoints = {
  ping: {{ path('public_speedtest_ping')|json_encode|raw }},
  download: {{ asset('speedtest.bin')|json_encode|raw }},
  upload: {{ path('public_speedtest_upload')|json_encode|raw }},
};

const speedtestState = {
  controller: null,
};

const speedtestElements = {
  start: document.getElementById('speedtest-start'),
  stop: document.getElementById('speedtest-stop'),
  externalStart: document.getElementById('external-speedtest-start'),
  bar: document.getElementById('speedtest-bar'),
  log: document.getElementById('speedtest-log'),
  ping: document.getElementById('speedtest-ping'),
  download: document.getElementById('speedtest-download'),
  upload: document.getElementById('speedtest-upload'),
  status: document.getElementById('speedtest-status'),
  detail: document.getElementById('speedtest-detail'),
};

const identifierValue = document.getElementById('identifier-value');
const identifierCopy = document.getElementById('identifier-copy');

function formatMs(value) {
  return `${Math.round(Number(value) || 0)} мс`;
}

function formatMbps(bitsPerSecond) {
  const value = Number(bitsPerSecond) || 0;
  if (value >= 1_000_000_000) {
    return `${(value / 1_000_000_000).toFixed(1)} Гбіт/с`;
  }
  return `${(value / 1_000_000).toFixed(1)} Мбіт/с`;
}

function setProgress(value) {
  speedtestElements.bar.style.width = `${Math.max(0, Math.min(100, value))}%`;
}

function setStatus(label, detail = '') {
  speedtestElements.status.textContent = label;
  speedtestElements.detail.textContent = detail;
}

function setLog(message) {
  speedtestElements.log.textContent = message;
}

function setBusy(isBusy) {
  speedtestElements.start.disabled = isBusy;
  speedtestElements.stop.disabled = !isBusy;
}

function resetResults() {
  speedtestElements.ping.textContent = '-';
  speedtestElements.download.textContent = '-';
  speedtestElements.upload.textContent = '-';
  setProgress(0);
  setStatus('Готово', 'Очікує запуску');
  setLog('Натисніть "Запустити тест", щоб почати.');
}

async function measurePing(signal) {
  const samples = [];

  for (let index = 0; index < 5; index += 1) {
    const startedAt = performance.now();
    const response = await fetch(`${speedtestEndpoints.ping}?t=${Date.now()}-${index}`, {
      cache: 'no-store',
      signal,
    });
    if (!response.ok) {
      throw new Error(`Ping failed: ${response.status}`);
    }
    samples.push(performance.now() - startedAt);
  }

  samples.sort((left, right) => left - right);
  return samples[Math.floor(samples.length / 2)];
}

async function measureDownload(signal) {
  const startedAt = performance.now();
  const streamCount = 4;

  const streamReads = Array.from({ length: streamCount }, async (_, index) => {
    const response = await fetch(`${speedtestEndpoints.download}?t=${Date.now()}-${index}`, {
      cache: 'no-store',
      signal,
    });
    if (!response.ok || !response.body) {
      throw new Error(`Download failed: ${response.status}`);
    }

    const reader = response.body.getReader();
    let receivedBytes = 0;
    while (true) {
      const { done, value } = await reader.read();
      if (done) {
        break;
      }
      receivedBytes += value.length;
    }

    return receivedBytes;
  });

  const receivedBytes = (await Promise.all(streamReads)).reduce((sum, bytes) => sum + bytes, 0);
  const elapsedSeconds = (performance.now() - startedAt) / 1000;
  return (receivedBytes * 8) / elapsedSeconds;
}

function buildUploadPayload(size) {
  const payload = new Uint8Array(size);
  for (let offset = 0; offset < payload.length; offset += 65536) {
    crypto.getRandomValues(payload.subarray(offset, Math.min(offset + 65536, payload.length)));
  }
  return payload;
}

async function uploadChunk(payload, signal) {
  const response = await fetch(speedtestEndpoints.upload, {
    method: 'POST',
    cache: 'no-store',
    signal,
    headers: {
      'Content-Type': 'application/octet-stream',
    },
    body: payload,
  });

  if (!response.ok) {
    if (response.status === 413) {
      throw new Error('Upload blocked by body-size limit');
    }
    throw new Error(`Upload failed: ${response.status}`);
  }

  return payload.byteLength;
}

async function measureUpload(signal) {
  const plans = [
    { streams: 4, size: 1024 * 1024 },
    { streams: 3, size: 512 * 1024 },
    { streams: 2, size: 256 * 1024 },
  ];
  let lastError = null;

  for (const plan of plans) {
    try {
      const startedAt = performance.now();
      const uploads = Array.from({ length: plan.streams }, () => uploadChunk(buildUploadPayload(plan.size), signal));
      const bytesSent = (await Promise.all(uploads)).reduce((sum, bytes) => sum + bytes, 0);
      const elapsedSeconds = (performance.now() - startedAt) / 1000;
      return (bytesSent * 8) / elapsedSeconds;
    } catch (error) {
      if (error?.name === 'AbortError') {
        throw error;
      }
      lastError = error;
      if (!String(error?.message || '').includes('body-size limit')) {
        break;
      }
    }
  }

  throw lastError || new Error('Upload failed');
}

async function runSpeedTest() {
  if (speedtestState.controller) {
    speedtestState.controller.abort();
  }

  speedtestState.controller = new AbortController();
  setBusy(true);
  setStatus('Підготовка', 'Запуск тесту');
  setLog('Перевірка ping...');
  setProgress(10);

  try {
    const pingMs = await measurePing(speedtestState.controller.signal);
    speedtestElements.ping.textContent = formatMs(pingMs);
    setStatus('Тестування', 'Вимірюю download');
    setLog('Вимірюється швидкість завантаження...');
    setProgress(40);

    const downloadMbps = await measureDownload(speedtestState.controller.signal);
    speedtestElements.download.textContent = formatMbps(downloadMbps);
    setStatus('Тестування', 'Вимірюю upload');
    setLog('Вимірюється швидкість відправки...');
    setProgress(75);

    try {
      const uploadMbps = await measureUpload(speedtestState.controller.signal);
      speedtestElements.upload.textContent = formatMbps(uploadMbps);
      setLog('Тест швидкості завершено.');
      setStatus('Готово', 'Тест завершено');
    } catch (uploadError) {
      if (uploadError?.name === 'AbortError') {
        throw uploadError;
      }
      console.warn('Upload step failed', uploadError);
      speedtestElements.upload.textContent = 'обмежено';
      setStatus('Частково', 'Upload заблоковано лімітом сервера');
      setLog('Download і ping пройшли. Upload обмежено серверним лімітом.');
      setProgress(100);
      return;
    }
    setProgress(100);
  } catch (error) {
    if (error?.name === 'AbortError') {
      setStatus('Зупинено', 'Тест перервано користувачем');
      setLog('Тест зупинено.');
    } else {
      console.warn('Speedtest failed', error);
      setStatus('Помилка', 'Не вдалося виконати тест');
      setLog(error?.message || 'Невідома помилка');
    }
  } finally {
    setBusy(false);
    speedtestState.controller = null;
  }
}

speedtestElements.start.addEventListener('click', runSpeedTest);
speedtestElements.stop.addEventListener('click', () => {
  if (speedtestState.controller) {
    speedtestState.controller.abort();
  }
});

speedtestElements.externalStart.addEventListener('click', () => {
  const width = 875;
  const height = 600;
  const left = Math.max(0, Math.round((screen.width - width) / 2));
  const top = Math.max(0, Math.round((screen.height - height) / 2));
  window.open(
    'https://2ip.ua/ru/myspeed',
    'speedo',
    `width=${width},height=${height},left=${left},top=${top},scrollbars=yes,resizable=yes`
  );
});

if (identifierCopy && identifierValue) {
  identifierCopy.addEventListener('click', async () => {
    const text = identifierValue.textContent?.trim() || '';
    if (!text || text === 'Не вказано') {
      return;
    }

    try {
      await navigator.clipboard.writeText(text);
      identifierCopy.textContent = 'Скопійовано';
      window.setTimeout(() => {
        identifierCopy.textContent = 'Скопіювати';
      }, 1200);
    } catch (error) {
      console.warn('Copy identifier failed', error);
      identifierCopy.textContent = 'Не вдалося';
      window.setTimeout(() => {
        identifierCopy.textContent = 'Скопіювати';
      }, 1200);
    }
  });
}

resetResults();
</script>
{% endblock %}

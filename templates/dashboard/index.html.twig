{% extends 'base.html.twig' %}
{% block title %}Панель{% endblock %}
{% block heading %}Панель{% endblock %}
{% block body %}
<div class="grid stats">
    <div class="stat"><div class="muted">Клієнти</div><div class="value" id="stat-clients">...</div></div>
    <div class="stat"><div class="muted">Пристрої</div><div class="value" id="stat-devices">...</div></div>
    <div class="stat"><div class="muted">Без зв'язку</div><div class="value" id="stat-unlinked">...</div></div>
    <div class="stat"><div class="muted">Трафік за сьогодні</div><div class="value" id="stat-traffic">...</div></div>
    <div class="stat"><div class="muted">Вхідний</div><div class="value" id="stat-download">...</div></div>
    <div class="stat"><div class="muted">Вихідний</div><div class="value" id="stat-upload">...</div></div>
    <div class="stat"><div class="muted">Локальний</div><div class="value" id="stat-local">...</div></div>
    <div class="stat"><div class="muted">Зовнішній / NAT</div><div class="value" id="stat-external">...</div></div>
</div>
<div id="dashboard-loading" class="muted" style="display:flex; align-items:center; gap:8px; margin:-4px 0 14px;">
    <span style="width:14px; height:14px; border:2px solid #d8dee8; border-top-color:#0f766e; border-radius:50%; display:inline-block; animation:spin .8s linear infinite;"></span>
    <span>Завантаження даних...</span>
</div>
<style>@keyframes spin { to { transform: rotate(360deg); } }</style>
<section class="panel" style="margin-bottom:16px;">
    <h2>Трафік в реальному часі</h2>
    <div class="grid stats" style="margin-bottom:10px;">
        <div class="stat"><div class="muted">Інтерфейс</div><div class="value" id="live-iface">...</div></div>
        <div class="stat"><div class="muted">Rx вхідний трафік</div><div class="value" id="live-rx">...</div></div>
        <div class="stat"><div class="muted">Tx вихідний трафік</div><div class="value" id="live-tx">...</div></div>
        <div class="stat"><div class="muted">Помилки / дропи</div><div class="value" id="live-errors">...</div></div>
    </div>
    <div class="muted" id="live-updated">Оновлення ще не виконувалось</div>
</section>
<div class="grid two">
    <section class="panel">
        <h2>Топ пристроїв за сьогодні</h2>
        <table>
            <thead><tr><th>MAC</th><th>IP</th><th>Юзер</th><th>Коментар</th><th>Усього</th><th>Вхідний</th><th>Вихідний</th></tr></thead>
            <tbody id="top-devices-body">
                <tr><td colspan="7" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Топ клієнтів за сьогодні</h2>
        <table>
            <thead><tr><th>Клієнт</th><th>Кімната</th><th>Коментар</th><th>Усього</th><th>Вхідний</th><th>Вихідний</th></tr></thead>
            <tbody id="top-clients-body">
                <tr><td colspan="6" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Топ застосунків</h2>
        <canvas id="appsChart" height="150"></canvas>
    </section>
    <section class="panel">
        <h2>Топ доменів</h2>
        <table>
            <tbody id="top-domains-body">
                <tr><td colspan="2" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Останні пристрої</h2>
        <table>
            <thead><tr><th>MAC</th><th>Ім'я хоста</th><th>Вперше побачено</th></tr></thead>
            <tbody id="latest-devices-body">
                <tr><td colspan="3" class="muted">Завантаження...</td></tr>
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
{% block scripts %}
<script>
const initialTopApps = {};
const appsChart = new Chart(document.getElementById('appsChart'), {
  type: 'bar',
  data: { labels: Object.keys(initialTopApps), datasets: [{ label: 'Трафік', data: Object.values(initialTopApps), backgroundColor: '#0f766e' }] },
  options: {
    responsive: true,
    plugins: {
      legend: { display: false },
      tooltip: {
        callbacks: {
          title: (items) => items[0]?.label || 'Unknown',
          label: (context) => formatBytes(context.parsed.y),
        },
      },
    },
    scales: {
      y: {
        ticks: {
          callback: (value) => formatBytes(value),
        },
      },
    },
  }
});

const dashboardApiUrl = {{ path('api_dashboard')|json_encode|raw }};
const mikrotikLiveUrl = {{ path('api_mikrotik_live_traffic')|json_encode|raw }};

function formatBytes(bytes) {
  const value = Number(bytes) || 0;
  if (value >= 1073741824) {
    return `${(value / 1073741824).toFixed(1)} ГБ`;
  }
  if (value >= 1048576) {
    return `${(value / 1048576).toFixed(1)} МБ`;
  }
  if (value >= 1024) {
    return `${(value / 1024).toFixed(1)} КБ`;
  }
  return `${value} Б`;
}

function formatRate(bitsPerSecond) {
  const value = Number(bitsPerSecond) || 0;
  if (value >= 1_000_000_000) return `${(value / 1_000_000_000).toFixed(1)} Гбіт/с`;
  if (value >= 1_000_000) return `${(value / 1_000_000).toFixed(1)} Мбіт/с`;
  if (value >= 1_000) return `${(value / 1_000).toFixed(1)} Кбіт/с`;
  return `${Math.round(value)} біт/с`;
}

function clearAndRender(tbody, rows) {
  if (rows.length === 0) {
    const columns = tbody.closest('table')?.querySelectorAll('thead th').length || 2;
    const line = document.createElement('tr');
    const cell = document.createElement('td');
    cell.colSpan = columns;
    cell.className = 'muted';
    cell.textContent = 'Немає даних';
    line.appendChild(cell);
    tbody.replaceChildren(line);
    return;
  }
  tbody.replaceChildren(...rows);
}

function textCell(text) {
  const cell = document.createElement('td');
  cell.textContent = text ?? '-';
  return cell;
}

function linkCell(label, href) {
  const cell = document.createElement('td');
  const link = document.createElement('a');
  link.href = href;
  link.textContent = label;
  cell.appendChild(link);
  return cell;
}

function renderTopDevices(rows) {
  const tbody = document.getElementById('top-devices-body');
  const tr = rows.map((row) => {
    const line = document.createElement('tr');
    line.appendChild(linkCell(row.mac || '-', `/devices/${row.id}`));
    line.appendChild(textCell(row.currentIp || '-'));
    if (row.clientId) {
      line.appendChild(linkCell(row.clientDisplayName || '-', `/clients/${row.clientId}`));
    } else {
      line.appendChild(textCell('не прив\'язано'));
    }
    line.appendChild(textCell(row.comment || '-'));
    line.appendChild(textCell(formatBytes(row.today)));
    line.appendChild(textCell(formatBytes(row.todayDownload)));
    line.appendChild(textCell(formatBytes(row.todayUpload)));
    return line;
  });
  clearAndRender(tbody, tr);
}

function renderTopClients(rows) {
  const tbody = document.getElementById('top-clients-body');
  const tr = rows.map((row) => {
    const line = document.createElement('tr');
    line.appendChild(linkCell(row.displayName || '-', `/clients/${row.id}`));
    line.appendChild(textCell(row.roomNumber || '-'));
    line.appendChild(textCell(row.comment || '-'));
    line.appendChild(textCell(formatBytes(row.today)));
    line.appendChild(textCell(formatBytes(row.todayDownload)));
    line.appendChild(textCell(formatBytes(row.todayUpload)));
    return line;
  });
  clearAndRender(tbody, tr);
}

function renderTopDomains(rows) {
  const tbody = document.getElementById('top-domains-body');
  const normalizedRows = Array.isArray(rows) ? rows : Object.entries(rows || {}).map(([domain, bytes]) => ({ domain, bytes }));
  const tr = normalizedRows.map((row) => {
    const line = document.createElement('tr');
    const domainCell = document.createElement('td');
    if (row.domain && row.domain !== 'Unknown') {
      const icon = document.createElement('img');
      icon.className = 'favicon';
      icon.alt = '';
      icon.src = `https://www.google.com/s2/favicons?domain=${encodeURIComponent(row.domain)}&sz=64`;
      domainCell.appendChild(icon);
    }
    domainCell.appendChild(document.createTextNode(row.domain || '-'));
    line.appendChild(domainCell);
    line.appendChild(textCell(formatBytes(row.bytes)));
    return line;
  });
  clearAndRender(tbody, tr);
}

function renderLatestDevices(rows) {
  const tbody = document.getElementById('latest-devices-body');
  const tr = rows.map((row) => {
    const line = document.createElement('tr');
    line.appendChild(textCell(row.mac || '-'));
    line.appendChild(textCell(row.hostname || '-'));
    line.appendChild(textCell(row.firstSeenAt ? new Date(row.firstSeenAt).toLocaleString() : '-'));
    return line;
  });
  clearAndRender(tbody, tr);
}

function updateMetrics(data) {
  document.getElementById('stat-clients').textContent = data.clients ?? 0;
  document.getElementById('stat-devices').textContent = data.devices ?? 0;
  document.getElementById('stat-unlinked').textContent = data.unlinkedDevices ?? 0;
  document.getElementById('stat-traffic').textContent = formatBytes(data.todayTraffic);
  const breakdown = data.todayTrafficBreakdown || {};
  document.getElementById('stat-download').textContent = formatBytes(breakdown.download);
  document.getElementById('stat-upload').textContent = formatBytes(breakdown.upload);
  document.getElementById('stat-local').textContent = formatBytes(breakdown.local);
  document.getElementById('stat-external').textContent = formatBytes(breakdown.external);
}

function updateAppsChart(topApps) {
  const normalized = topApps || {};
  appsChart.data.labels = Object.keys(normalized);
  appsChart.data.datasets[0].data = Object.values(normalized).map((bytes) => Number(bytes || 0));
  appsChart.update();
}

function updateLiveTraffic(data) {
  document.getElementById('live-iface').textContent = data.interface || '-';
  document.getElementById('live-rx').textContent = formatRate(data.rxBitsPerSecond);
  document.getElementById('live-tx').textContent = formatRate(data.txBitsPerSecond);
  const errors = [
    Number(data.rxErrorsPerSecond) || 0,
    Number(data.txErrorsPerSecond) || 0,
    Number(data.rxDropsPerSecond) || 0,
    Number(data.txDropsPerSecond) || 0,
    Number(data.txQueueDropsPerSecond) || 0,
  ].reduce((sum, value) => sum + value, 0);
  document.getElementById('live-errors').textContent = `${errors}`;
  document.getElementById('live-updated').textContent = `Оновлено: ${new Date().toLocaleTimeString()}`;
}

function applyDashboard(data) {
  updateMetrics(data);
  renderTopDevices(data.topDevices || []);
  renderTopClients(data.topClients || []);
  renderTopDomains(data.topDomains || []);
  renderLatestDevices(data.latestDevices || []);
  updateAppsChart(data.topApps || {});
  const loading = document.getElementById('dashboard-loading');
  if (loading) {
    loading.hidden = true;
  }
}

function loadDashboard() {
  return fetch(dashboardApiUrl, { headers: { Accept: 'application/json' } })
    .then((response) => response.ok ? response.json() : Promise.reject(new Error(`Dashboard API ${response.status}`)))
    .then((data) => {
      applyDashboard(data);
      return data;
    });
}

function loadLiveTraffic() {
  return fetch(mikrotikLiveUrl, { headers: { Accept: 'application/json' }, cache: 'no-store' })
    .then((response) => response.ok ? response.json() : Promise.reject(new Error(`Live traffic API ${response.status}`)))
    .then((data) => {
      updateLiveTraffic(data);
      return data;
    });
}

loadDashboard()
  .catch((error) => {
    console.warn('Dashboard load failed', error);
    const loading = document.getElementById('dashboard-loading');
    if (loading) {
      loading.textContent = 'Не вдалося завантажити дані.';
    }
  })
  .finally(() => {
    loadLiveTraffic().catch((error) => console.warn('Live traffic load failed', error));
    window.setInterval(() => {
      loadDashboard().catch((error) => console.warn('Dashboard refresh failed', error));
    }, 15000);
    window.setInterval(() => {
      loadLiveTraffic().catch((error) => console.warn('Live traffic refresh failed', error));
    }, 1000);
  });
</script>
{% endblock %}

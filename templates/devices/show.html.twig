{% extends 'base.html.twig' %}
{% block title %}Device {{ device.mac }}{% endblock %}
{% block heading %}Device {{ device.mac }}{% endblock %}
{% block body %}
<div class="grid stats">
    <div class="stat"><div class="muted">IP</div><div class="value">{{ device.currentIp ?: '-' }}</div></div>
    <div class="stat"><div class="muted">Today</div><div class="value">{{ (todayBytes / 1048576)|number_format(1) }} MB</div></div>
    <div class="stat"><div class="muted">30 days</div><div class="value">{{ (monthBytes / 1048576)|number_format(1) }} MB</div></div>
    <div class="stat"><div class="muted">Client</div><div class="value">{{ device.client ? device.client.displayName : 'unlinked' }}</div></div>
</div>
<div class="grid two">
    <section class="panel"><h2>30-day usage</h2><canvas id="usageChart" height="160"></canvas></section>
    <section class="panel"><h2>IP history</h2><table><tr><th>IP</th><th>First</th><th>Last</th></tr>{% for h in ipHistory %}<tr><td>{{ h.ip }}</td><td>{{ h.firstSeenAt|date('Y-m-d H:i') }}</td><td>{{ h.lastSeenAt|date('Y-m-d H:i') }}</td></tr>{% endfor %}</table></section>
    <section class="panel"><h2>Latest flows</h2><table><tr><th>Time</th><th>Direction</th><th>Source</th><th>Destination</th><th>Total</th></tr>{% for f in flows %}<tr><td>{{ f.receivedAt|date('Y-m-d H:i') }}</td><td>{{ f.direction }}</td><td>{{ f.srcIp }}{% if f.srcPort %}:{{ f.srcPort }}{% endif %}</td><td>{{ f.dstIp }}{% if f.dstPort %}:{{ f.dstPort }}{% endif %}</td><td>{{ (f.bytes / 1048576)|number_format(1) }} MB</td></tr>{% endfor %}</table></section>
</div>
{% endblock %}
{% block scripts %}
<script>
new Chart(document.getElementById('usageChart'), {
  type: 'line',
  data: { labels: {{ daily|map(u => u.date|date('Y-m-d'))|json_encode|raw }}, datasets: [{ label: 'MB', data: {{ daily|map(u => (u.totalBytes / 1048576)|round(1))|json_encode|raw }}, borderColor: '#0f766e', backgroundColor: 'rgba(15,118,110,.12)', fill: true }] }
});
</script>
{% endblock %}

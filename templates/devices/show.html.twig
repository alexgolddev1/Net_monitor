{% extends 'base.html.twig' %}
{% block title %}Пристрій {{ device.mac }}{% endblock %}
{% block heading %}Пристрій {{ device.mac }}{% endblock %}
{% block body %}
<div class="grid stats">
    <div class="stat"><div class="muted">IP</div><div class="value">{{ device.currentIp ?: '-' }}</div></div>
    <div class="stat"><div class="muted">Сьогодні</div><div class="value">{{ (todayBytes / 1048576)|number_format(1) }} МБ</div></div>
    <div class="stat"><div class="muted">30 днів</div><div class="value">{{ (monthBytes / 1048576)|number_format(1) }} МБ</div></div>
    <div class="stat"><div class="muted">Клієнт</div><div class="value">{{ device.client ? device.client.displayName : 'не прив'язано' }}</div></div>
</div>
<div class="grid two">
    <section class="panel"><h2>Активність за 30 днів</h2><canvas id="usageChart" height="160"></canvas></section>
    <section class="panel"><h2>Історія IP</h2><table><tr><th>IP</th><th>Перше</th><th>Останнє</th></tr>{% for h in ipHistory %}<tr><td>{{ h.ip }}</td><td>{{ h.firstSeenAt|date('Y-m-d H:i') }}</td><td>{{ h.lastSeenAt|date('Y-m-d H:i') }}</td></tr>{% else %}<tr><td colspan="3">Немає даних</td></tr>{% endfor %}</table></section>
</div>
<div class="grid two">
    <section class="panel">
        <h2>Останні домени</h2>
        <table>
            <thead><tr><th>Домени</th><th>Останнє</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for row in recentDomains %}
                <tr>
                    <td>{{ row.domain }}</td>
                    <td>{{ row.lastSeenAt ? row.lastSeenAt|date('Y-m-d H:i') : '-' }}</td>
                    <td>{{ (row.bytes / 1048576)|number_format(1) }} МБ</td>
                </tr>
            {% else %}
                <tr><td colspan="3">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Топ доменів за сьогодні</h2>
        <table>
            <thead><tr><th>Домен</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for row in topDomainsToday %}
                <tr><td>{{ row.domain }}</td><td>{{ (row.bytes / 1048576)|number_format(1) }} МБ</td></tr>
            {% else %}
                <tr><td colspan="2">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
<div class="grid two">
    <section class="panel">
        <h2>Топ застосунків за сьогодні</h2>
        <table>
            <thead><tr><th>Застосунок</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for app, bytes in topAppsToday %}
                <tr><td>{{ app }}</td><td>{{ (bytes / 1048576)|number_format(1) }} МБ</td></tr>
            {% else %}
                <tr><td colspan="2">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
    <section class="panel">
        <h2>Остання активність</h2>
        <table>
            <thead><tr><th>Час</th><th>Домен / застосунок</th><th>Напрямок</th><th>Обсяг</th></tr></thead>
            <tbody>
            {% for row in recentActivity %}
                <tr>
                    <td>{{ row.receivedAt ? row.receivedAt|date('Y-m-d H:i') : '-' }}</td>
                    <td>{{ row.label }}</td>
                    <td>{{ row.direction }}</td>
                    <td>{{ (row.bytes / 1048576)|number_format(1) }} МБ</td>
                </tr>
            {% else %}
                <tr><td colspan="4">Немає даних</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
{% block scripts %}
{% set usageLabels = [] %}
{% set usageValues = [] %}
{% for usage in daily %}
    {% set usageLabels = usageLabels|merge([usage.date|date('Y-m-d')]) %}
    {% set usageValues = usageValues|merge([(usage.totalBytes / 1048576)|round(1)]) %}
{% endfor %}
<script type="application/json" id="usageChartLabels">{{ usageLabels|json_encode|raw }}</script>
<script type="application/json" id="usageChartValues">{{ usageValues|json_encode|raw }}</script>
<script>
const usageLabels = JSON.parse(document.getElementById('usageChartLabels').textContent);
const usageValues = JSON.parse(document.getElementById('usageChartValues').textContent);
new Chart(document.getElementById('usageChart'), {
  type: 'line',
  data: {
    labels: usageLabels,
    datasets: [{
      label: 'МБ',
      data: usageValues,
      borderColor: '#0f766e',
      backgroundColor: 'rgba(15,118,110,.12)',
      fill: true
    }]
  }
});
</script>
{% endblock %}

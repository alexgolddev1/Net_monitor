{% extends 'base.html.twig' %}
{% block title %}Пристрої{% endblock %}
{% block heading %}Пристрої{% endblock %}
{% block body %}
<table>
    <tr><th>MAC</th><th>Поточний IP</th><th>Ім'я хоста</th><th>Виробник</th><th>VLAN</th><th>Клієнт</th><th>Сьогодні</th><th>Остання активність</th><th>Прив'язка</th></tr>
    {% for row in devices %}
        <tr>
            <td><a href="{{ path('device_show',{id:row.device.id}) }}">{{ row.device.mac }}</a></td>
            <td>{{ row.device.currentIp }}</td>
            <td>{{ row.device.hostname }}</td>
            <td>{{ row.device.vendor }}</td>
            <td>{{ row.device.vlan }}</td>
            <td>{% if row.device.client %}<a href="{{ path('client_show',{id:row.device.client.id}) }}">{{ row.device.client.displayName }}</a>{% else %}<span class="muted">не прив'язано</span>{% endif %}</td>
            <td>{{ (row.today / 1048576)|number_format(1) }} МБ</td>
            <td>{{ row.device.lastSeenAt ? row.device.lastSeenAt|date('Y-m-d H:i') : '-' }}</td>
            <td><button type="button" onclick="document.getElementById('link-{{ row.device.id }}').showModal()">Прив'язати</button></td>
        </tr>
    {% endfor %}
</table>
{% for row in devices %}
<dialog id="link-{{ row.device.id }}" class="panel">
    <h2>Прив'язати {{ row.device.mac }}</h2>
    <form method="post" action="{{ path('device_link_client',{id:row.device.id}) }}">
        <label>Існуючий клієнт</label>
        <select name="client_id"><option value="">Створити нового</option>{% for client in clients %}<option value="{{ client.id }}">{{ client.displayName }}{% if client.roomNumber %}, {{ client.roomNumber }}{% endif %}</option>{% endfor %}</select>
        <div class="form-grid">
            <div><label>ПІБ</label><input name="full_name"></div>
            <div><label>Кімната</label><input name="room_number"></div>
            <div><label>Телефон</label><input name="phone"></div>
        </div>
        <label>Коментар</label><textarea name="comment"></textarea>
        <div style="margin-top:12px; display:flex; gap:8px;"><button>Зберегти</button><button type="button" class="secondary" onclick="this.closest('dialog').close()">Скасувати</button></div>
    </form>
</dialog>
{% endfor %}
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Пристрої{% endblock %}
{% block heading %}Пристрої{% endblock %}
{% block body %}
<form method="get" style="display:flex; justify-content:flex-end; margin-bottom:12px;">
    <label style="display:flex; align-items:center; gap:8px; margin:0; cursor:pointer;">
        <input type="checkbox" name="hide_linked" value="1" {% if hideLinked %}checked{% endif %} onchange="this.form.submit()" style="width:auto;">
        <span>Сховати прив'язані пристрої</span>
    </label>
</form>
<table>
    <tr><th>MAC</th><th>Поточний IP</th><th>Ім'я хоста</th><th>Виробник</th><th>VLAN</th><th>Клієнт</th><th>Усього</th><th>Вхідний</th><th>Вихідний</th><th>Топ домени сьогодні</th><th>Остання активність</th><th>Дії</th></tr>
    {% for row in devices %}
        <tr>
            <td><a href="{{ path('device_show',{id:row.device.id}) }}">{{ row.device.mac }}</a></td>
            <td>{{ row.device.currentIp }}</td>
            <td>{{ row.device.hostname }}</td>
            <td>{{ row.device.vendor }}</td>
            <td>{{ row.device.vlan }}</td>
            <td>{% if row.device.clientId %}<a href="{{ path('client_show',{id:row.device.clientId}) }}">{{ row.device.clientDisplayName }}</a>{% else %}<span class="muted">не прив'язано</span>{% endif %}</td>
            <td>{{ (row.today / 1048576)|number_format(1) }} МБ</td>
            <td>{{ (row.todayDownload / 1048576)|number_format(1) }} МБ</td>
            <td>{{ (row.todayUpload / 1048576)|number_format(1) }} МБ</td>
            <td>
                {% for domain in row.topDomains %}
                    <div>{{ domain.domain }} <span class="muted">{{ (domain.bytes / 1048576)|number_format(1) }} МБ</span></div>
                {% else %}
                    <span class="muted">-</span>
                {% endfor %}
            </td>
            <td>{{ row.device.lastSeenAt ? row.device.lastSeenAt|date('Y-m-d H:i') : '-' }}</td>
            <td>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <button type="button" onclick="document.getElementById('link-{{ row.device.id }}').showModal()">
                        {% if row.device.clientId %}Редагувати коментар{% else %}Прив'язати{% endif %}
                    </button>
                    {% if row.device.clientId %}
                        <form method="post" action="{{ path('device_unlink_client', {id: row.device.id}) }}" style="margin:0;">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('device_unlink_client_' ~ row.device.id) }}">
                            <button type="submit" class="secondary" onclick="return confirm('Відв\'язати пристрій?')">Відв'язати</button>
                        </form>
                    {% endif %}
                </div>
            </td>
        </tr>
    {% else %}
        <tr><td colspan="12" class="muted">Немає даних</td></tr>
    {% endfor %}
</table>
{% for row in devices %}
<dialog id="link-{{ row.device.id }}" class="panel">
    <h2>{% if row.device.clientId %}Редагувати прив'язку{% else %}Прив'язати{% endif %} {{ row.device.mac }}</h2>
    <form method="post" action="{{ path('device_link_client',{id:row.device.id}) }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('device_link_client_' ~ row.device.id) }}">
        <label>Існуючий клієнт</label>
        <select name="client_id" data-client-select><option value="">Створити нового</option>{% for client in clients %}<option value="{{ client.id }}" {% if row.device.clientId and row.device.clientId == client.id %}selected{% endif %}>{{ client.displayName }}{% if client.roomNumber %}, {{ client.roomNumber }}{% endif %}</option>{% endfor %}</select>
        <div class="form-grid" data-new-client-fields>
            <div><label>ПІБ</label><input name="full_name"></div>
            <div><label>Кімната</label><input name="room_number"></div>
            <div><label>Телефон</label><input name="phone"></div>
        </div>
        <label>Коментар до пристрою</label><textarea name="comment">{{ row.device.comment }}</textarea>
        <div style="margin-top:12px; display:flex; gap:8px;"><button>Зберегти</button><button type="button" class="secondary" onclick="this.closest('dialog').close()">Скасувати</button></div>
    </form>
</dialog>
{% endfor %}
{% endblock %}
{% block scripts %}
<script>
document.querySelectorAll('dialog[id^="link-"]').forEach((dialog) => {
  const select = dialog.querySelector('[data-client-select]');
  const newClientFields = dialog.querySelector('[data-new-client-fields]');
  const inputs = newClientFields ? newClientFields.querySelectorAll('input') : [];

  const syncClientFields = () => {
    const useExistingClient = select && select.value !== '';
    if (!newClientFields) {
      return;
    }
    newClientFields.hidden = useExistingClient;
    inputs.forEach((input) => {
      input.disabled = useExistingClient;
      if (useExistingClient) {
        input.value = '';
      }
    });
  };

  if (select) {
    select.addEventListener('change', syncClientFields);
    syncClientFields();
  }
});
</script>
{% endblock %}

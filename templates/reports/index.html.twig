{% extends 'base.html.twig' %}
{% block title %}Звіти{% endblock %}
{% block heading %}Звіти{% endblock %}
{% block body %}
<div class="grid two">
    <section class="panel">
        <h2>Щоденний звіт</h2>
        <table>
            <tr><th>Клієнт</th><th>Кімната</th><th>Трафік</th></tr>
            {% for row in daily %}
                <tr>
                    <td>{{ row.fullName ?: "Не прив'язано" }}</td>
                    <td>{{ row.roomNumber }}</td>
                    <td>{{ (row.totalBytes / 1048576)|number_format(1) }} МБ</td>
                </tr>
            {% endfor %}
        </table>
    </section>
    <section class="panel">
        <h2>Місячний звіт</h2>
        <table>
            <tr><th>Клієнт</th><th>Кімната</th><th>Трафік</th></tr>
            {% for row in monthly %}
                <tr>
                    <td>{{ row.fullName ?: "Не прив'язано" }}</td>
                    <td>{{ row.roomNumber }}</td>
                    <td>{{ (row.totalBytes / 1048576)|number_format(1) }} МБ</td>
                </tr>
            {% endfor %}
        </table>
    </section>
</div>
<p>
    <a class="btn" href="{{ path('reports_daily_csv') }}">Щоденний CSV</a>
    <a class="btn" href="{{ path('reports_monthly_csv') }}">Місячний CSV</a>
    <a class="btn secondary" href="/api/reports/daily">Щоденний JSON</a>
    <a class="btn secondary" href="/api/reports/monthly">Місячний JSON</a>
</p>
{% endblock %}
